{
  "expo": {
    "name": "Tucus",
    "slug": "tucus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tucus.musicplayer",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Tucus needs microphone access for audio visualization",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.tucus.musicplayer"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
